      "name": "3. POST - Register Client (Random Data)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const random = Math.random().toString(36).substring(2,10);",
              "pm.variables.set(\"clientName\", \"AsadQA_\" + random);",
              "pm.variables.set(\"clientEmail\", \"asad.\" + random + \"@test.com\");"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Client Created 201\", () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "console.log(\"Access Token:\", json.accessToken);",
              "pm.collectionVariables.set(\"accessToken\", json.accessToken);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
